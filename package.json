{
  "name": "abstraxion-dashboard",
  "version": "0.15.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:mobile": "vite --port 3000 --host",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "changeset": "changeset",
    "preview": "vite preview",
    "types": "wrangler types",
    "lint": "eslint",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "checkdotenv": "[ ! -f .env ] || (echo 'Error: .env file present. Please remove it or rename to .env.local before building for mainnet.' && exit 1)",
    "build:mainnet": "npm run checkdotenv && vite build --mode mainnet",
    "build:testnet": "npm run checkdotenv && vite build --mode testnet",
    "build:mainnet-beta": "vite build --mode mainnet-beta",
    "build:testnet-beta": "vite build --mode testnet-beta",
    "deploy:mainnet-beta": "npm run build:mainnet-beta && wrangler deploy",
    "deploy:testnet-beta": "npm run build:testnet-beta && wrangler deploy",
    "publish:packages": "changeset publish",
    "version:packages": "changeset version",
    "wrangler-dev": "wrangler dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.1",
    "@burnt-labs/abstraxion-core": "^1.0.0-alpha.58",
    "@burnt-labs/constants": "^0.1.0-alpha.11",
    "@burnt-labs/signers": "^1.0.0-alpha.2",
    "@burnt-labs/xion-auth-sdk": "^0.3.1",
    "@cosmjs/cosmwasm-stargate": "^0.32.4",
    "@cosmjs/crypto": "^0.32.4",
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@delphi-labs/shuttle": "^4.3.0",
    "@delphi-labs/shuttle-react": "^4.3.0",
    "@github/webauthn-json": "^2.1.1",
    "@metamask/providers": "^18.1.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@stytch/react": "^19.0.0",
    "@stytch/vanilla-js": "^5.41.1",
    "@tanstack/react-query": "^5.74.4",
    "axios": "^1.13.2",
    "bech32": "^2.0.0",
    "camelcase-keys": "^10.0.1",
    "class-variance-authority": "^0.7.1",
    "cosmjs-types": "^0.9.0",
    "jose": "^5.1.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.6",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@cloudflare/vite-plugin": "^1.4.3",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@keplr-wallet/types": "^0.12.143",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.13",
    "autoprefixer": "^10.4.13",
    "brace-expansion": "^4.0.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.20",
    "prettier": "^3.6.2",
    "stream-browserify": "^3.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vitest": "^4.0.13",
    "wrangler": "^4.50.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.22.2"
  },
  "overrides": {
    "vite-plugin-node-polyfills": {
      "vite": "$vite"
    }
  }
}
