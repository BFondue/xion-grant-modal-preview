# Stytch Configuration (REQUIRED)
VITE_STYTCH_PUBLIC_TOKEN=public-token-test-your-token-here

# Network Configuration
VITE_CHAIN_ID=xion-testnet-2
VITE_NETWORK=testnet-2

# XION API Configuration
VITE_XION_API_URL=https://api.xion-testnet-2.burnt.com
VITE_XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com
VITE_XION_STYTCH_API=http://localhost:8787

# Gas Configuration
VITE_GAS_ADJUSTMENT=1.8
VITE_GAS_MARGIN=5000
VITE_GAS_PRICE=0.001uxion

# Feature Flags (Mainnet Only - defaults to true for testnet)
# Set to "true" to enable on mainnet
VITE_OKX_FLAG=false
VITE_METAMASK_FLAG=false
VITE_PASSKEY_FLAG=true
VITE_KEPLR_FLAG=false
VITE_TIKTOK_FLAG=false
VITE_APPLE_FLAG=false

# Network Configuration
# Set to "mainnet" for production, "testnet-2" for development
VITE_NETWORK=testnet-2

# Indexer Configuration
VITE_INDEXER_STRATEGY="numia"
VITE_DEFAULT_INDEXER_URL="https://api.subquery.network/sq/burnt-labs/xion-testnet-2-indexer"
VITE_NUMIA_TOKEN="your-numia-token-here"
VITE_NUMIA_URL="https://xion-testnet-2.numia.xyz/v3/"

# Default API Configuration
VITE_DEFAULT_API_URL=https://api.xion-testnet-2.burnt.com

# Fee Granter Configuration
VITE_FEE_GRANTER_ADDRESS=xion1xrqz2wpt4rw8rtdvrc4n4yn5h54jm0nn4evn2x
